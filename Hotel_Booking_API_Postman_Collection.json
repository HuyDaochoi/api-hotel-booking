{
  "info": {
    "name": "Hotel Booking API - Core Test Cases",
    "description": "Bộ test API theo kịch bản từ User đến Admin (đáp ứng 8 test cases của đồ án)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. AUTHENTICATION (Phân quyền)",
      "item": [
        {
          "name": "1.1 Register Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer1@gmail.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Nguyen Van Khach\",\n  \"phoneNumber\": \"0987654321\"\n}"
            }
          }
        },
        {
          "name": "1.2 Login Customer (Extract Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"userToken\", jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer1@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "1.3 Login Admin (Extract Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"adminToken\", jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. USER FLOW (Search & Book)",
      "item": [
        {
          "name": "2.1 Search Available Rooms (Tra cứu phòng)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/search", "host": ["{{baseUrl}}"], "path": ["search"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkInDate\": \"2026-10-01\",\n  \"checkOutDate\": \"2026-10-05\",\n  \"numGuests\": 2\n}"
            }
          }
        },
        {
          "name": "2.2 Create Booking (Thành công - Extract ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set(\"bookingId\", jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"checkInDate\": \"2026-10-01\",\n  \"checkOutDate\": \"2026-10-05\",\n  \"numGuests\": 2,\n  \"specialRequests\": \"Phòng yên tĩnh\",\n  \"paymentMethod\": \"CASH\"\n}"
            }
          }
        },
        {
          "name": "2.3 Create Booking (Test Trùng Lịch Overlap - Failed)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"checkInDate\": \"2026-10-03\",\n  \"checkOutDate\": \"2026-10-07\",\n  \"numGuests\": 2,\n  \"specialRequests\": \"Test chống trùng lịch\",\n  \"paymentMethod\": \"CASH\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. ADMIN FLOW (Manage Booking)",
      "item": [
        {
          "name": "3.1 Admin Confirm Booking",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/admin/bookings/{{bookingId}}/confirm", "host": ["{{baseUrl}}"], "path": ["admin","bookings","{{bookingId}}","confirm"]}
          }
        },
        {
          "name": "3.2 Admin Check-in",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/admin/bookings/{{bookingId}}/check-in", "host": ["{{baseUrl}}"], "path": ["admin","bookings","{{bookingId}}","check-in"]}
          }
        }
      ]
    },
    {
      "name": "4. CANCELLATION FLOW (Hủy & Hoàn tiền)",
      "item": [
        {
          "name": "4.1 Create Booking 2 (Dành cho Test Hủy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set(\"bookingId2\", jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 2,\n  \"checkInDate\": \"2026-11-01\",\n  \"checkOutDate\": \"2026-11-03\",\n  \"numGuests\": 1,\n  \"paymentMethod\": \"CASH\"\n}"
            }
          }
        },
        {
          "name": "4.2 Admin Confirm Booking 2 (Thu tiền cọc)",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{adminToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/admin/bookings/{{bookingId2}}/confirm", "host": ["{{baseUrl}}"], "path": ["admin","bookings","{{bookingId2}}","confirm"]}
          }
        },
        {
          "name": "4.3 User Cancel Booking 2 (Test Tự động Hoàn tiền)",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{userToken}}"}
            ],
            "url": {"raw": "{{baseUrl}}/bookings/{{bookingId2}}/cancel", "host": ["{{baseUrl}}"], "path": ["bookings","{{bookingId2}}","cancel"]}
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookingId",
      "value": "",
      "type": "string"
    },
    {
      "key": "bookingId2",
      "value": "",
      "type": "string"
    }
  ]
}
